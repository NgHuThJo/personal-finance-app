{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.Seq"],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore.Mvc": "Warning",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.AspNetCore.HttpLogging.HttpLoggingMiddleware": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://backend:5341"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"],
    "Properties": {
      "Application": "Personal Finance App"
    }
  },
  "App": {
    "FrontendUrl": "https://frontend.purpleglacier-a86aea1c.polandcentral.azurecontainerapps.io",
    "BackendUrl": "http://backend",
    "FrontendRedirectUrl": "https://frontend.purpleglacier-a86aea1c.polandcentral.azurecontainerapps.io/redirect"
  },
  "Jwt": {
    "Schemas": {
      "Bearer": {
        "Issuer": "https://frontend.purpleglacier-a86aea1c.polandcentral.azurecontainerapps.io",
        "Audience": "api://",
        "Expires": 10
      }
    }
  },
  "Authentication": {
    "Google": {
      "Authority": "https://accounts.google.com"
    },
    "GitHub": {
      "Authority": "https://github.com/login/oauth"
    }
  }
}
